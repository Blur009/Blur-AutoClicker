{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MrSchnirschuhHub",
  "version": "3.8.0",
  "identifier": "com.mrschnirschuh.hub",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run frontend:build",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MrSchnirschuhHub",
        "width": 500,
        "height": 150,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "maximizable": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Overlay",
        "fullscreen": true,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "createUpdaterArtifacts": false,
    "publisher": "Pandi",
    "copyright": "Copyright (c) Pandi",
    "category": "Utility",
    "shortDescription": "Configurable auto clicker with Logitech device support.",
    "longDescription": "Performance-focused auto clicker with global hotkeys, Logitech G502/G502X device control (DPI, RGB, macros), and advanced timing. Linux native.",
    "homepage": "https://github.com/MrSchnirschuh/MrSchnirschuhHub",
    "icon": ["icons/icon.png"],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libhidapi-hidraw0", "xdotool"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}